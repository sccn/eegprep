{
  "defaults": {
    "window_size": [1100, 750],
    "timeout_seconds": 90
  },
  "cases": [
    {
      "id": "main_window",
      "description": "Main EEGLAB-style application window after startup.",
      "targets": {
        "eeglab": {
          "type": "matlab_figure",
          "matlab_command": "eeglab;"
        },
        "eegprep": {
          "type": "command",
          "action": "main_window"
        }
      }
    },
    {
      "id": "adjust_events_dialog",
      "description": "Adjust event latencies dialog opened from pop_adjustevents.",
      "window_size": [858, 169],
      "timeout_seconds": 120,
      "targets": {
        "eeglab": {
          "type": "matlab_dialog",
          "action": "pop_adjustevents"
        },
        "eegprep": {
          "type": "command",
          "action": "adjust_events_dialog",
          "command": [
            "{python}",
            "-m",
            "eegprep.functions.guifunc.visual_capture",
            "--case",
            "{case_id}",
            "--output",
            "{output}"
          ]
        }
      }
    },
    {
